# --- Server ---
PORT=3000
RUST_LOG=info,s3_explorer=debug,tower_http=info

# --- Auth ---
# Set EXPLORER_USER and EXPLORER_PASS to enable Basic Auth.
# Leave blank to disable (do NOT do this in production).
EXPLORER_USER=admin
EXPLORER_PASS=changeme

# --- S3 / Railway Bucket (set as Railway Variable References) ---
BUCKET=
ACCESS_KEY_ID=
SECRET_ACCESS_KEY=
ENDPOINT=https://storage.railway.app
REGION=auto

# --- Tunables ---
# Presigned URL lifetime (seconds). Default 900 (15m).
PRESIGN_TTL_SECS=900
# Max upload size in bytes. Default 100 MiB.
MAX_UPLOAD_BYTES=104857600
# Public base URL used to build absolute presigned / proxy links.
# On Railway, leave blank and it will use the Host header. Set explicitly
# when behind a custom domain.
PUBLIC_BASE_URL=
