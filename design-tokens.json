{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "bg": { "dark": "#0f1115", "light": "#fafbfc" },
    "bg-elev": { "dark": "#161a22", "light": "#ffffff" },
    "bg-elev-2": { "dark": "#1c2230", "light": "#f3f5f8" },
    "bg-hover": { "dark": "#232a3a", "light": "#eef1f5" },
    "fg": { "dark": "#e7ecf3", "light": "#0d1117" },
    "fg-muted": { "dark": "#8a93a6", "light": "#5a6473" },
    "fg-subtle": { "dark": "#5a6473", "light": "#8a93a6" },
    "border": { "dark": "#262d3b", "light": "#e3e6ec" },
    "border-strong": { "dark": "#3a4356", "light": "#c8ced8" },
    "accent": { "dark": "#4f8cff", "light": "#2c6cf5" },
    "accent-hover": { "dark": "#6aa1ff", "light": "#1d57d4" },
    "accent-fg": { "dark": "#ffffff", "light": "#ffffff" },
    "accent-soft": { "dark": "rgba(79,140,255,0.12)", "light": "rgba(44,108,245,0.10)" },
    "ok": { "dark": "#34c759", "light": "#16a34a" },
    "warn": { "dark": "#f5a623", "light": "#d97706" },
    "danger": { "dark": "#ef5b5b", "light": "#dc2626" },
    "danger-soft": { "dark": "rgba(239,91,91,0.12)", "light": "rgba(220,38,38,0.08)" }
  },
  "space": {
    "1": "4px",
    "2": "8px",
    "3": "12px",
    "4": "16px",
    "5": "24px",
    "6": "32px",
    "7": "48px"
  },
  "radius": {
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "pill": "999px"
  },
  "font": {
    "sans": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif",
    "mono": "ui-monospace, SFMono-Regular, Menlo, Consolas, 'Liberation Mono', monospace"
  },
  "text": {
    "xs": { "size": "11px", "lineHeight": 1.4 },
    "sm": { "size": "13px", "lineHeight": 1.5 },
    "base": { "size": "14px", "lineHeight": 1.55 },
    "md": { "size": "16px", "lineHeight": 1.5 },
    "lg": { "size": "18px", "lineHeight": 1.4 },
    "xl": { "size": "22px", "lineHeight": 1.3 }
  },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,0.25)",
    "md": "0 6px 16px rgba(0,0,0,0.35)",
    "lg": "0 16px 40px rgba(0,0,0,0.45)"
  },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "duration-fast": "100ms",
    "duration-base": "180ms",
    "duration-slow": "280ms"
  },
  "breakpoint": {
    "sm": "640px",
    "md": "800px",
    "lg": "1100px"
  }
}
